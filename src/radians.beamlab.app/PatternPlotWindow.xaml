<Window x:Class="radians.beamlab.app.PatternPlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Beam pattern (S.1528-1 §1.4 Taylor)"
        Height="520" Width="780"
        Background="#ffffff"
        Foreground="#1a1a1a"
        FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="HeaderText" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap"/>
        <Border Grid.Row="1" BorderBrush="#cccccc" BorderThickness="1" Background="#fafafa">
            <Canvas x:Name="PlotCanvas" SizeChanged="PlotCanvas_SizeChanged" ClipToBounds="True"/>
        </Border>
        <TextBlock Grid.Row="2" Margin="0,4,0,0" Foreground="#666666"
                   Text="Y: gain (dBi).  X: off-axis angle θ (degrees).  Dashed line: 3-dB edge θ = θb.  Floor line: LF."/>
    </Grid>
</Window>
